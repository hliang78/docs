{
  "profileId": "remote-apply-worker",
  "description": "High-risk worker profile for explicit approved remote apply operations with tight target, command, and evidence boundaries.",
  "supportedTaskKinds": [
    "remote_apply"
  ],
  "supportedEnvironmentKinds": [
    "remote_apply",
    "local_workspace"
  ],
  "contextTolerance": {
