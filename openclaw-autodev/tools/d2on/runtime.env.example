# Copy this file to an operator-controlled location outside the repository,
# then point d2on at it with:
#
#   export D2ON_RUNTIME_ENV_FILE="/absolute/path/to/runtime.env"
#   /Users/huangliang/project/OneOPS-ALL/scripts/openclaw-agent-loop.sh start d2on
#
# Default profile-based location if you do not override D2ON_RUNTIME_ENV_FILE:
#   /Users/huangliang/.openclaw-aigocode-direct/runtime.env
#
# Runtime secrets must never be committed.
#
# Worker model selection happens before this file is sourced. If you want to
# switch d2on onto a cloud worker such as aigocode/gpt-5.4-mini, export
# OPENCLAW_AGENT_MODEL / PROVIDER_PROBE_MODEL in the invoking shell first.
#
# Provider credentials may still live here because they are needed later, when
# OpenClaw actually makes model requests.

export AIGOCODE_API_KEY="<runtime secret for aigocode/gpt-5.4-mini>"

# Browser/UI validation account. If omitted, current D2 smoke scripts fall back
# to admin/admin@123, but runtime injection is preferred so the account source
# is explicit and rotatable.
export D2_UI_LOGIN_USERNAME="admin"
export D2_UI_LOGIN_PASSWORD="<runtime secret or admin@123>"
export D2_FE_BASE_URL="http://127.0.0.1:3002"
export D2_CHROME_PORT="9223"

# Read-only MySQL candidate lookup
export D2ON_MYSQL_HOST="127.0.0.1"
export D2ON_MYSQL_PORT="3306"
export D2ON_MYSQL_DATABASE="oneops"
export D2ON_MYSQL_USER="readonly_user"
export D2ON_MYSQL_PASSWORD="<runtime secret>"

# Optional backend API verification
export D2ON_CONTROLLER_URL="http://127.0.0.1:18080"
export D2ON_X_AUTH_TOKEN="<runtime token>"
export D2ON_CONTROLLER_INSECURE_SKIP_VERIFY="0"

# Preferred controller-backed remote verification credentials
export D2ON_SERVER_SSH_USER="root"
export D2ON_SERVER_SSH_PASSWORD="<runtime secret>"
export D2ON_NETWORK_SSH_USER="admin"
export D2ON_NETWORK_SSH_PASSWORD="<runtime secret>"
export D2ON_NETWORK_AUTH_PASSWORD="<runtime secret if enable/auth is required>"

# Optional direct helper credentials for read-only fallback discovery
